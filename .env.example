# Copy this file to .env and edit the values before running the app.
#
# For Docker Compose, the DATABASE_URL below uses the internal postgres service
# name from docker-compose.yml, so you do not need to expose Postgres to your host.

ENV=production
PORT=8080

# Required
DATABASE_URL=postgres://postgres:postgres@postgres:5432/opportunity_radar?sslmode=disable

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL=24h
SCHEDULER_RUN_ON_START=true
SCHEDULER_RUN_TIMEOUT=30m

# Optional email sender configuration.
# If these are left blank, digest emails are logged instead of sent.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=Opportunity Radar

# Digest recipient, digest lookback, and top-N are configured in the app UI
# after startup, not through environment variables.
